generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  password         String
  name             String
  course           String?
  semester         String?
  subjects         Subject[]
  role             String            @default("student")
  dailyStudyHours  Float?            @default(4.0)
  dailyStudyGoal   Float             @default(4.0)
  streak           Int               @default(0)
  lastActive       DateTime?
  focusMode        Boolean           @default(false)
  pomodoroSessions PomodoroSession[]
  tasks            Task[]
  createdAt        DateTime          @default(now())
}

model Task {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  userId      Int
  user        User      @relation(fields: [userId], references: [id])
  createdAt   DateTime  @default(now())
}

model Subject {
  id            Int             @id @default(autoincrement())
  name          String
  description   String?
  difficulty    Int             @default(3)
  priority      Int             @default(3)
  userId        Int
  user          User            @relation(fields: [userId], references: [id])
  exams         Exam[]
  studySessions StudySession[]
  topics        Topic[]
  createdAt     DateTime        @default(now())
}

model Exam {
  id        Int      @id @default(autoincrement())
  date      DateTime
  subjectId Int
  subject   Subject  @relation(fields: [subjectId], references: [id])
}

model Topic {
  id          Int      @id @default(autoincrement())
  name        String
  isCompleted Boolean  @default(false)
  difficulty  Int      @default(3)
  subjectId   Int
  subject     Subject  @relation(fields: [subjectId], references: [id])
}

model StudySession {
  id         Int      @id @default(autoincrement())
  startTime  DateTime
  endTime    DateTime
  subjectId  Int
  subject    Subject  @relation(fields: [subjectId], references: [id])
  isDone     Boolean  @default(false)
  focusTopic String?
}

model PomodoroSession {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
  durationMinutes Int      @default(25)
  completedAt     DateTime @default(now())
}
